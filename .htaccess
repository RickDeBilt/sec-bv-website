# S.E.C. B.V. — Apache/LiteSpeed configuratie
# (wordt genegeerd op servers zonder .htaccess-ondersteuning, bijv. nginx)

# Nette 404-pagina
ErrorDocument 404 /index.html

# Beveiliging: blokkeer toegang tot config met inloggegevens
# (extra vangnet mocht private/ per ongeluk in de webroot staan)
<FilesMatch "contact-config\.php$">
  Require all denied
</FilesMatch>

# GZIP-compressie
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# Cache-headers: statische assets lang cachen, HTML kort
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>
